<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /php/liforinpharmaceutical/


    RewriteRule ^$ index.php [L]
    RewriteRule ^index/?$ index.php [L]
    RewriteRule ^careers/?$ careers.php [L]
    RewriteRule ^company-profile/?$ company-profile.php [L]
    RewriteRule ^about/?$ about.php [L]
    RewriteRule ^services/?$ services.php [L]
    RewriteRule ^contact-us/?$ contact-us.php [L]
    RewriteRule ^enquiry-now/?$ enquiry-now.php [L]
    RewriteRule ^domestic-products/?$ domestic-products.php [L]
    RewriteRule ^domestic-products/?$ domestic-products.php [L]
    RewriteRule ^export-products/?$ export-products.php [L]
    RewriteRule ^export-products/?$ export-products.php [L]
    RewriteRule ^team/?$ team.php [L]
    RewriteRule ^why-us/?$ why-us.php [L]
    RewriteRule ^global-presence/?$ global-presence.php [L]
    RewriteRule ^domestic-products/?$ domestic-products.php [L]
    RewriteRule ^export-products/?$ export-products.php [L]
    RewriteRule ^product-listing/?$ product-listing.php [L]
    RewriteRule ^product_details/?$ product_details.php [L]


    # -----------------------------
    # 1. Product Details (3-level URL)
    # /parentCategory-slug/category-slug/product-slug
    # -----------------------------
    #RewriteRule ^([a-zA-Z0-9-_]+)/([a-zA-Z0-9-_]+)/?$ product-details.php?category=$1&slug=$2 [L,QSA]
    # /parent-slug/category-slug/product-slug
    RewriteRule ^([a-zA-Z0-9-_]+)/([a-zA-Z0-9-_]+)/([a-zA-Z0-9-_]+)/?$ product-details.php?parent=$1&category=$2&slug=$3 [L,QSA]
    # -----------------------------
    # 2. Product Category (1-level URL)
    # /category-slug
    # -----------------------------
    RewriteRule ^([a-zA-Z0-9-_]+)/?$ products.php?slug=$1 [L,QSA]

    # -----------------------------
    # 3. Redirect OLD URLs → NEW SEO URLs
    # -----------------------------

    # /product-listing?slug=abc → /abc
    RewriteCond %{THE_REQUEST} \s/product-listing\?slug=([^&\s]+) [NC]
    RewriteRule ^product-listing$ %1? [R=301,L]

    # /product-listing/product-details/abc → /category/abc (dynamic not possible fully)
    # you will handle category in PHP if needed

    # -----------------------------
    # 4. Remove .php extension (keep last)
    # -----------------------------
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME}.php -f
    RewriteRule ^([^/.]+)/?$ $1.php [L]

</IfModule>